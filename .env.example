# Discord webhook URL. Keep the real value private in .env.
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-id/your-webhook-token

# Palworld REST API.
# Local app outside Docker:
# PALWORLD_REST_BASE_URL=http://127.0.0.1:8212/v1/api
#
# App in Docker, Palworld REST on the Docker host:
# PALWORLD_REST_BASE_URL=http://host.docker.internal:8212/v1/api
#
# App in Docker/VPS, Palworld REST on another server:
# PALWORLD_REST_BASE_URL=http://your-palworld-server-ip:8212/v1/api
PALWORLD_REST_BASE_URL=http://127.0.0.1:8212/v1/api
PALWORLD_REST_USERNAME=admin
PALWORLD_REST_PASSWORD=change-me

# Public game server address shown in Discord.
PALWORLD_GAME_ADDRESS=127.0.0.1:8211

# Refresh behavior.
REFRESH_INTERVAL_SECONDS=30
REQUEST_TIMEOUT_SECONDS=10
METRICS_REFRESH_SECONDS=30
PLAYERS_REFRESH_SECONDS=30
STATIC_REFRESH_SECONDS=600

# Runtime files. Docker compose overrides these to /app/data.
MESSAGE_ID_FILE=.discord-message-id
STATE_FILE=.palworld-webhook-state.json
MESSAGE_TEMPLATE_FILE=message-template.jsonc
ICONS_FILE=icons.jsonc

# Timezone and scheduled restart.
TIME_ZONE=Asia/Jakarta
RESTART_ENABLED=false
RESTART_TIMES=04:00
RESTART_WAIT_SECONDS=300
RESTART_MESSAGE=Scheduled restart in 5 minutes. Please log out safely.

# Discord display.
MAX_PLAYER_NAMES=10
